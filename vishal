<label><input type="radio" name="payment" value="UPI"> UPI</label>
<label><input type="radio" name="payment" value="Card"> Credit / Debit Card</label>

<button onclick="placeOrder()">Place Order</button>
</div>

<script>

let currentProduct={}
let currentQty=1
let cart=[]

function openProduct(name,cal,protein,carbs,fats,price,desc,img){

currentProduct={name,cal,price}

currentQty=1

qtyDisplay.innerText=1

pName.innerText=name
pCal.innerText=cal+" kcal"
pProtein.innerText=protein+" g"
pCarbs.innerText=carbs+" g"
pFats.innerText=fats+" g"
pDesc.innerText=desc
pImg.src=img

home.style.display="none"
productView.style.display="block"
}

function addToCart(){

const existing=cart.find(i=>i.name===currentProduct.name)

if(existing){
existing.qty+=currentQty
}else{
cart.push({...currentProduct,qty:currentQty})
}

cartPopupMsg.innerText=currentQty+" × "+currentProduct.name+" added to your cart!"
cartPopup.style.display="flex"
}

function toggleCart(){

home.style.display="none"
productView.style.display="none"
cartDiv.style.display="block"

let html=""
let total=0

cart.forEach(i=>{
let itemTotal=i.price*i.qty
total+=itemTotal
html+=`<p>${i.qty} × ${i.name} — ₹${itemTotal}</p>`
})

if(cart.length===0) html="<p>Your cart is empty.</p>"

cartItems.innerHTML=html
cartTotal.innerText="Total: ₹"+total
}

function goToCheckout(){

cartDiv.style.display="none"
checkout.style.display="block"

let total=0
cart.forEach(i=>{ total+=i.price*i.qty })

checkoutTotal.innerText="Total Amount: ₹"+total
}

</script>

