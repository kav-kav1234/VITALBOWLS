<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Vital Bowl</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;}

body{
font-family:Arial;
background-image:url("https://images.pexels.com/photos/3429783/pexels-photo-3429783.jpeg?auto=compress&cs=tinysrgb&w=1600");
background-size:cover;
background-position:center;
background-attachment:fixed;
}

/* HEADER */

header{
display:flex;
justify-content:space-between;
padding:30px 60px;
background:white;
}

.logo{
font-size:40px;
font-weight:bold;
}

nav a{
margin-left:20px;
text-decoration:none;
color:black;
font-weight:500;
cursor:pointer;
}

/* HERO */

.hero{
text-align:center;
padding:60px 20px;
background:rgba(255,255,255,0.9);
margin:40px 60px;
border-radius:10px;
}

.hero h1{
font-size:42px;
margin-bottom:15px;
}

.hero p{
font-size:18px;
max-width:800px;
margin:auto;
line-height:1.6;
}

/* PRODUCTS */

.products{
display:flex;
flex-wrap:wrap;
gap:20px;
padding:40px 60px;
}

.card{
width:220px;
height:200px;
background-size:cover;
background-position:center;
border-radius:10px;
padding:10px;
color:white;
text-decoration:none;
font-weight:bold;
position:relative;
cursor:pointer;
}

.card div{
background:rgba(0,0,0,0.5);
padding:6px;
border-radius:5px;
position:absolute;
bottom:10px;
left:10px;
}

/* PRODUCT VIEW */

#productView{
display:none;
padding:40px 60px;
}

.product-box{
display:flex;
gap:40px;
background:white;
padding:20px;
}

.product-box img{
width:350px;
height:300px;
object-fit:cover;
}

button{
padding:10px 20px;
background:#1e73be;
color:white;
border:none;
cursor:pointer;
margin-top:10px;
}

/* CART + CHECKOUT */

.section{
display:none;
background:white;
padding:20px;
margin:40px 60px;
}

input,textarea{
display:block;
margin:10px 0;
padding:8px;
width:300px;
}

label{
display:block;
margin:5px 0;
}

/* QUANTITY */

.qty-control{
display:flex;
align-items:center;
gap:12px;
margin:12px 0;
}

.qty-btn{
width:34px;
height:34px;
background:#1e73be;
color:white;
border:none;
border-radius:50%;
font-size:20px;
cursor:pointer;
display:flex;
align-items:center;
justify-content:center;
}

.qty-num{
font-size:20px;
font-weight:bold;
min-width:30px;
text-align:center;
}

/* FEEDBACK SIDEBAR */

.feedback{
position:fixed;
right:0;
top:50%;
transform:translateY(-50%);
background:white;
padding:15px;
border-radius:10px 0 0 10px;
box-shadow:0 0 10px rgba(0,0,0,0.2);
text-align:center;
z-index:1000;
}

.feedback button{
display:block;
margin:8px auto;
font-size:20px;
background:none;
border:none;
cursor:pointer;
}

/* ALL POPUPS */

.overlay-popup{
position:fixed;
top:0;left:0;
width:100%;height:100%;
background:rgba(0,0,0,0.6);
display:none;
align-items:center;
justify-content:center;
z-index:2000;
}

.popup-box{
background:white;
padding:30px;
border-radius:10px;
text-align:center;
width:350px;
}

.popup-box h2{
margin-bottom:10px;
}

.popup-box p{
margin-bottom:5px;
font-size:16px;
}

.popup-box button{
margin-top:15px;
}
</style>
</head>

<body>

